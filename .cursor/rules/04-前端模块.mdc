### 弹窗表单 (ArcoModalFormShow)

新增/编辑统一使用函数式弹窗表单：

```typescript
import { ArcoModalFormShow, formHelper, ruleHelper } from "@easyfe/admin-component";
import { cloneDeep } from "lodash-es";

function onEdit(row: DetailType | null) {
    const tempValue = cloneDeep(row);
    ArcoModalFormShow({
        modalConfig: {
            title: tempValue ? "编辑" : "新建"
        },
        value: tempValue || {},
        formConfig: [
            formHelper.input("名称", "name", {
                rules: [ruleHelper.require("请输入")]
            }),
            formHelper.select("类型", "type", options, {
                rules: [ruleHelper.require("请选择")]
            }),
            formHelper.textarea("备注", "remark")
        ],
        ok: async (data: any) => {
            if (tempValue) {
                await updateApi(data);
            } else {
                await addApi(data);
            }
            table.value.refresh();
        }
    });
}
```

