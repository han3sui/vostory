# 前端模块

本项目前端基于 Vue 3 + TypeScript + Vite + Arco Design Vue + `@easyfe/admin-component` 私有组件库构建。

具体可以参考 @/web/src/views/system 目录下使用方式。

## 技术栈

- Vue 3 (Composition API + `<script setup>`)
- TypeScript
- Vite 4
- Arco Design Vue (`@arco-design/web-vue`)
- `@easyfe/admin-component` (私有封装组件库)
- Pinia (状态管理)
- Vue Router 4
- TailwindCSS
- dayjs / lodash-es / ECharts

## 项目结构约定

```
web/src/
├── config/
│   ├── apis/          # API 接口定义（按业务模块拆分）
│   ├── router/        # 路由配置（按业务模块拆分）
│   ├── pinia/         # Pinia Store
│   └── vite/          # Vite 插件配置
├── hooks/             # 组合式函数
├── packages/          # 核心封装（request、vue-router、init）
├── views/
│   ├── utils/         # 页面级工具函数
│   ├── components/    # 页面级公共组件
│   └── [module]/      # 业务模块页面
├── utils/             # 通用工具函数
├── layout/            # 布局组件
└── locales/           # 国际化
```

## 新增模块步骤

### 1. 添加 API 接口定义

在 @/web/src/config/apis 目录下，新建对应的接口文件。

```typescript
// src/config/apis/[module].ts
import request from "@/packages/request";

// 1. 先定义类型
export type ItemDetailType = {
    id: number;
    name: string;
    status: string;
    // ...
};

// 2. 定义 API 函数
export function getList(params?: Record<string, any>): Promise<{
    data: ItemDetailType[];
    total: number;
}> {
    return request({ url: "/api/v1/items", method: "get", params });
}

export function getDetail(id: number): Promise<ItemDetailType> {
    return request({ url: `/api/v1/items/${id}`, method: "get" });
}

export function create(data: Partial<ItemDetailType>): Promise<ItemDetailType> {
    return request({ url: "/api/v1/items", method: "post", data });
}

export function update(data: Partial<ItemDetailType>): Promise<void> {
    return request({ url: `/api/v1/items/${data.id}`, method: "put", data });
}

export function remove(id: number): Promise<void> {
    return request({ url: `/api/v1/items/${id}`, method: "delete" });
}

export function enable(id: number): Promise<void> {
    return request({ url: `/api/v1/items/${id}/enable`, method: "put" });
}

export function disable(id: number): Promise<void> {
    return request({ url: `/api/v1/items/${id}/disable`, method: "put" });
}
```

### 2. 添加页面

在 @/web/src/views 目录下，新建对应的页面文件。文件名称始终为 index.vue，通过创建目录放不同的页面。

- **简单页面**：列表和新建、编辑都在一个页面里（如岗位模块 `@/web/src/views/system/post/index.vue`）
- **复杂页面**：新建 list、edit 目录进行区分处理（参考 `@/web/src/views/iot/device`）

### 3. 添加路由

在 @/web/src/configs/router 下，新建对应的路由模块。

```typescript
// src/config/router/[module].ts
import { RouteConfig } from "types";
import Layout from "@/layout/index.vue";
import { hasPermission } from "@/views/utils";

const routers: RouteConfig[] = [
    {
        path: "/module",
        name: "module",
        meta: { title: "模块名", icon: "menu-icon", sort: 200 },
        component: Layout,
        children: [
            {
                path: "/module/list",
                name: "module-list",
                meta: {
                    title: "列表",
                    sort: 1,
                    keepAliveName: "ModuleList",
                    permission: () => hasPermission("module:list")
                },
                component: () => import("@/views/module/list/index.vue")
            },
            {
                path: "/module/detail",
                name: "module-detail",
                meta: {
                    title: "详情",
                    hidden: true,
                    navTag: true,
                    parentName: "module-list",
                    permission: () => hasPermission("module:detail")
                },
                component: () => import("@/views/module/detail/index.vue")
            }
        ]
    }
];
export default routers;
```

## 核心组件使用规范

### 列表页标准模式 (arco-table)

列表页统一使用 `<arco-table>` 组件，配合 `tableHelper` 和 `formHelper` 构建。

```vue
<template>
    <frame-view>
        <arco-table ref="table" :table-config="tableConfig" :req="getData">
            <template #tlBtns>
                <arco-form v-model="filterData" layout="row" :config="filterConfig" />
            </template>
            <template #switchSlot>
                <a-table-column title="启用">
                    <template #cell="{ record }">
                        <a-switch
                            :disabled="!hasPermission('module:enable')"
                            :default-checked="record.status === '0'"
                            :before-change="() => handleToggle(record)"
                        />
                    </template>
                </a-table-column>
            </template>
        </arco-table>
    </frame-view>
</template>
<script lang="ts" setup>
import { ArcoTable, formHelper, tableHelper, ArcoForm } from "@easyfe/admin-component";
import { hasPermission, PageTableConfig } from "@/views/utils";

const table = ref();
const filterData = ref({});

const filterConfig = computed(() => {
    return [
        formHelper.input("名称", "name", { span: 6, debounce: 500 }),
        formHelper.select("状态", "status", [
            { label: "正常", value: "0" },
            { label: "停用", value: "1" }
        ], { span: 6 })
    ];
});

const getData = computed(() => {
    return {
        fn: apiFunction,
        params: { ...filterData.value }
    };
});

const tableConfig = computed(() => {
    return tableHelper.create({
        ...PageTableConfig,
        arcoProps: { rowKey: "id" },
        maxHeight: "auto",
        trBtns: [
            {
                label: "新建",
                type: "primary",
                if: () => hasPermission("module:action:add"),
                handler: () => onEdit(null)
            }
        ],
        columns: [
            tableHelper.default("名称", "name"),
            tableHelper.link("链接列", "field", (row) => { /* 跳转 */ }),
            tableHelper.date("时间", "created_at", { format: "YYYY-MM-DD HH:mm:ss" }),
            tableHelper.status("状态", "status", (item) => ({
                text: item.status === "0" ? "正常" : "停用",
                status: item.status === "0" ? "success" : "danger"
            })),
            tableHelper.slot("switchSlot"),
            tableHelper.btns("操作", [
                {
                    label: "编辑",
                    if: () => hasPermission("module:action:edit"),
                    handler: (row) => onEdit(row)
                },
                {
                    label: "删除",
                    status: "danger",
                    if: () => hasPermission("module:action:remove"),
                    handler: (row) => onDelete(row)
                }
            ])
        ]
    });
});
</script>
```

