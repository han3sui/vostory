## 页面模式约定

### 列表页 (list/index.vue)
- 使用 `<frame-view>` 包裹
- `<arco-table>` + `<arco-form>` 筛选
- 简单 CRUD 用 `ArcoModalFormShow` 弹窗
- 复杂详情跳转独立页面

### 详情页 (detail/index.vue)
- `<frame-view>` + `<a-page-header>` 带返回
- `<a-tabs>` 分标签展示
- `<a-descriptions>` 展示基础信息
- 编辑按钮触发 `ArcoModalFormShow`

### 独立表单页 (form.vue / edit/index.vue)
- `<frame-view :page-header="{ title }">` 带标题
- `<arco-form>` 表单
- `<template #bottom>` 放操作按钮

## API 定义规范

```typescript
// src/config/apis/[module].ts
import request from "@/packages/request";

// 1. 先定义类型
export type ItemDetailType = {
    id: number;
    name: string;
    status: string;
    // ...
};

// 2. 定义 API 函数
export function getList(params?: Record<string, any>): Promise<{
    data: ItemDetailType[];
    total: number;
}> {
    return request({ url: "/api/v1/items", method: "get", params });
}

export function getDetail(id: number): Promise<ItemDetailType> {
    return request({ url: `/api/v1/items/${id}`, method: "get" });
}

export function create(data: Partial<ItemDetailType>): Promise<ItemDetailType> {
    return request({ url: "/api/v1/items", method: "post", data });
}

export function update(data: Partial<ItemDetailType>): Promise<void> {
    return request({ url: `/api/v1/items/${data.id}`, method: "put", data });
}

export function remove(id: number): Promise<void> {
    return request({ url: `/api/v1/items/${id}`, method: "delete" });
}
```

## 路由定义规范

```typescript
// src/config/router/[module].ts
import { RouteConfig } from "types";
import Layout from "@/layout/index.vue";
import { hasPermission } from "@/views/utils";

const routers: RouteConfig[] = [
    {
        path: "/module",
        name: "module",
        meta: { title: "模块名", icon: "menu-icon", sort: 200 },
        component: Layout,
        children: [
            {
                path: "/module/list",
                name: "module-list",
                meta: {
                    title: "列表",
                    sort: 1,
                    keepAliveName: "ModuleList",  // 页面缓存名
                    permission: () => hasPermission("module:list")
                },
                component: () => import("@/views/module/list/index.vue")
            },
            {
                path: "/module/detail",
                name: "module-detail",
                meta: {
                    title: "详情",
                    hidden: true,       // 菜单隐藏
                    navTag: true,       // 显示导航标签
                    parentName: "module-list",  // 父级路由名
                    permission: () => hasPermission("module:detail")
                },
                component: () => import("@/views/module/detail/index.vue")
            }
        ]
    }
];
export default routers;
```

## 常用模式

### 删除确认
```typescript
Modal.confirm({
    title: "删除",
    content: `确认删除【${row.name}】？`,
    onBeforeOk: async () => {
        await deleteApi(row.id);
        Message.success("删除成功");
