### 启用/禁用开关
```vue
<template #switchSlot>
    <a-table-column title="启用">
        <template #cell="{ record }">
            <a-switch
                :disabled="!hasPermission('module:enable')"
                :default-checked="record.status === '0'"
                :before-change="() => handleToggle(record)"
            />
        </template>
    </a-table-column>
</template>
```
```typescript
async function handleToggle(row: DetailType) {
    try {
        if (row.status === "0") {
            await disableApi(row.id);
        } else {
            await enableApi(row.id);
        }
        table.value.refresh();
        return true;
    } catch { return false; }
}
```

