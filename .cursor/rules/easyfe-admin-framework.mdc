### 3. 弹窗表单 (ArcoModalFormShow)

新增/编辑统一使用函数式弹窗表单：

```typescript
import { ArcoModalFormShow, formHelper, ruleHelper } from "@easyfe/admin-component";
import { cloneDeep } from "lodash-es";

function onEdit(row: DetailType | null) {
    const tempValue = cloneDeep(row);
    ArcoModalFormShow({
        modalConfig: {
            title: tempValue ? "编辑" : "新建"
        },
        value: tempValue || {},
        formConfig: [
            formHelper.input("名称", "name", {
                rules: [ruleHelper.require("请输入")]
            }),
            formHelper.select("类型", "type", options, {
                rules: [ruleHelper.require("请选择")]
            }),
            formHelper.textarea("备注", "remark")
        ],
        ok: async (data: any) => {
            if (tempValue) {
                await updateApi(data);
            } else {
                await addApi(data);
            }
            table.value.refresh();
        }
    });
}
```

### 4. 独立表单页 (arco-form)

复杂表单使用独立页面 + `<arco-form>` 组件：

```vue
<template>
    <frame-view :page-header="{ title: '表单标题' }">
        <arco-form ref="form" v-model="formData" :config="formConfig">
            <template #s1>
                <!-- 自定义插槽内容 -->
            </template>
        </arco-form>
        <template #bottom>
            <a-space>
                <a-button @click="handleCancel">取消</a-button>
                <a-button type="primary" :loading="loading" @click="handleSave">保存</a-button>
            </a-space>
        </template>
    </frame-view>
</template>
<script lang="ts" setup>
const form = ref();
const formData = ref({ /* 初始值 */ });

const formConfig = computed(() => [
    formHelper.section("基础信息"),
    formHelper.input("名称", "name", { rules: [ruleHelper.require("不能为空")] }),
    formHelper.slot("s1"),
    formHelper.section("配置参数"),
    // 动态字段...
]);

async function handleSave() {
    await formHelper.validate(form.value);
    // 提交逻辑
}
</script>
```

### 5. formHelper 完整 API

```typescript
// 基础表单项
formHelper.input(label, key, options?)        // 文本输入
formHelper.inputNumber(label, key, options?)  // 数字输入
formHelper.textarea(label, key, options?)     // 多行文本
formHelper.select(label, key, data[], options?) // 下拉选择
formHelper.treeSelect(label, key, data[], options?) // 树形选择
formHelper.radio(label, key, data[], { type: "radio" }) // 单选
formHelper.checkbox(label, key, data[], options?) // 多选
formHelper.switch(label, key, options?)       // 开关
formHelper.datePicker(label, key, options?)   // 日期选择
formHelper.rangePicker(label, key, options?)  // 日期范围
formHelper.time(label, key, options?)         // 时间选择
formHelper.color(label, key, options?)        // 颜色选择
formHelper.editor(label, key, options?)       // 富文本
formHelper.picUpload(label, key, options?)    // 图片上传
formHelper.upload(label, key, options?)       // 文件上传

// 布局/辅助
formHelper.section(title)                     // 分组标题
formHelper.slot(slotName)                     // 自定义插槽
formHelper.span(label, key)                   // 纯文本展示（支持HTML）

// 表单验证
formHelper.validate(formRef)                  // 验证表单
ruleHelper.require(message, trigger?)         // 必填规则
ruleHelper.phone()                            // 手机号规则

// 常用 options 属性
{
    span: 6,                    // 栅格宽度（筛选表单用）
    debounce: 500,              // 防抖（搜索输入用）
    rules: [],                  // 验证规则
    disabled: boolean,          // 禁用
    if: (formData) => boolean,  // 条件显示
    labelTips: string,          // label 提示
    inputTips: string,          // 输入框下方提示
    onChange: (value) => void,  // 值变化回调
    allowSearch: true,          // 下拉可搜索
    multiple: true,             // 多选
    fieldNames: {},             // 字段映射
    formType: "password",       // 密码输入
    maxLength: 50,              // 最大长度
    showWordLimit: true,        // 显示字数
    virtualListProps: { height: 300 }, // 虚拟列表（大数据量下拉）
    triggerProps: { autoFitPopupMinWidth: true } // 下拉宽度自适应
}
```

### 6. tableHelper 完整 API

```typescript
tableHelper.create(config)                    // 创建表格配置
